{
  "name": "@aiready/visualizer",
  "version": "0.7.24",
  "description": "Interactive graph visualization for AIReady analysis results",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "aiready-visualize": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./graph": {
      "types": "./dist/graph/index.d.ts",
      "import": "./dist/graph/index.js",
      "require": "./dist/graph/index.js"
    }
  },
  "files": [
    "dist",
    "web/dist",
    "web/src",
    "web/index.html",
    "web/vite.config.ts",
    "web/tsconfig.json",
    "web/package.json",
    "web/public"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "lint": "eslint src web/src --ext .ts,.tsx,.js,.jsx",
    "dev:web": "cd web && vite",
    "dev:watch-report": "node ../scripts/watch-report.js",
    "build": "tsup && cd web && vite build",
    "build:cli": "tsup",
    "build:web": "cd web && vite build",
    "typecheck": "tsc --noEmit && cd web && tsc --noEmit",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "format-check": "prettier --check . --ignore-path ../../.prettierignore",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "lint:fix": "eslint . --fix",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "aiready",
    "visualization",
    "graph",
    "d3",
    "dependency-graph"
  ],
  "author": "Peng Cao <caopengau@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/getaiready/aiready-visualizer.git"
  },
  "dependencies": {
    "@aiready/core": "workspace:*",
    "commander": "^14.0.3",
    "d3": "^7.9.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "regenerator-runtime": "^0.14.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.5",
    "vitest": "^4.1.4"
  }
}
