{
  "name": "@aiready/clawmart",
  "version": "0.1.0",
  "description": "API client for ClawMart integration",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "chalk": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsup": "^8.3.5",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "aiready",
    "clawmart",
    "ai-agents",
    "monetization"
  ],
  "license": "MIT",
  "private": true,
  "publishConfig": {
    "access": "restricted"
  }
}
